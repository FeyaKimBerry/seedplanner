# Copy this file to .env and fill in your Google OAuth Client ID.
# Get one at: https://console.cloud.google.com → APIs & Services → Credentials
# → Create Credentials → OAuth 2.0 Client ID → Web application
#
# Add these to "Authorized JavaScript origins":
#   http://localhost:5173        (Vite dev server)
#   https://your-production-domain.com
VITE_GOOGLE_CLIENT_ID=

# Purchase gate — access code(s) the buyer types once to unlock the app on a
# device. Comma-separated so you can accept an old and a new code during a
# rotation window (e.g. OLDCODE2024,NEWCODE2025). If unset, a hardcoded default
# ("SEEDPLANNER") is used. This is anti-casual-piracy only, NOT real security.
VITE_ACCESS_CODES=
